{
  "name": "WhoamiSec — JARVIS MIND Live",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/sshd": {
      "version": "latest",
      "sshUser": "codespace"
    },
    "ghcr.io/devcontainers/features/git": "latest",
    "ghcr.io/devcontainers/features/node": "lts",
    "ghcr.io/devcontainers/features/docker-in-docker": {
      "version": "latest",
      "dockerDashComposeVersion": "v2"
    }
  },
  "forwardPorts": [8080, 5001, 22, 5004, 5005, 11434],
  "portsAttributes": {
    "8080": {
      "label": "whoamisec.com (Web)",
      "onAutoForward": "openPreview",
      "visibility": "public"
    },
    "5001": {
      "label": "Flask API",
      "onAutoForward": "silent",
      "visibility": "public"
    },
    "5004": {
      "label": "JARVIS Admin",
      "onAutoForward": "silent",
      "visibility": "public"
    },
    "5005": {
      "label": "Subscriptions",
      "onAutoForward": "silent",
      "visibility": "public"
    },
    "22": {
      "label": "SSH",
      "onAutoForward": "silent",
      "visibility": "private"
    },
    "11434": {
      "label": "Ollama AI",
      "onAutoForward": "silent",
      "visibility": "private"
    }
  },
  "postCreateCommand": "bash /workspace/.devcontainer/setup.sh",
  "postStartCommand": "bash /workspace/.devcontainer/start-services.sh",
  "remoteUser": "codespace",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
