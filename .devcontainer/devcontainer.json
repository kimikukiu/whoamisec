{
  "name": "WhoamiSec - Live VPS Deployment",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/sshd": {
      "version": "latest",
      "sshUser": "codespace"
    },
    "ghcr.io/devcontainers/features/git": "latest",
    "ghcr.io/devcontainers/features/node": "lts"
  },
  "forwardPorts": [8080, 5001, 22, 5004, 5005],
  "portsAttributes": {
    "8080": { "label": "Nginx Web Server", "onAutoForward": "notify" },
    "5001": { "label": "Flask API Backend", "onAutoForward": "notify" },
    "22": { "label": "SSH Server", "onAutoForward": "notify" },
    "5004": { "label": "JARVIS Admin Panel", "onAutoForward": "notify" },
    "5005": { "label": "Subscriptions Service", "onAutoForward": "notify" }
  },
  "postCreateCommand": "bash /workspace/.devcontainer/setup.sh",
  "postStartCommand": "bash /workspace/.devcontainer/start-services.sh",
  "remoteUser": "codespace",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
