<?xml version="1.0" encoding="utf-8"?>
<!-- WHOAMISecAI Main — WebView + Bottom Navigation (Home, Chat, Builder, JARVIS, Settings) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0a0a0f">

    <!-- WebView Container -->
    <FrameLayout
        android:id="@+id/webview_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <WebView
            android:id="@+id/webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Splash overlay -->
        <FrameLayout
            android:id="@+id/splash_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#0a0a0f">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@mipmap/ic_launcher_round"
                    android:contentDescription="WHOAMISecAI" />

                <ProgressBar
                    android:id="@+id/splash_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="200dp"
                    android:layout_height="4dp"
                    android:layout_marginTop="24dp"
                    android:progressTint="#8b5cf6"
                    android:progressBackgroundTint="#1a1a2e"
                    android:max="100" />

                <TextView
                    android:id="@+id/splash_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Loading…"
                    android:textColor="#666"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

    <!-- Bottom Navigation Bar (5 items: Home, Chat, Builder, JARVIS, Settings) -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#0d0d14"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <!-- Home -->
        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_view"
                android:contentDescription="Home"
                android:backgroundTint="#8b5cf6" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="#8b5cf6"
                android:textSize="9sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Chat -->
        <LinearLayout
            android:id="@+id/nav_chat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_send"
                android:contentDescription="Chat"
                android:backgroundTint="#555" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat"
                android:textColor="#555"
                android:textSize="9sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Builder -->
        <LinearLayout
            android:id="@+id/nav_builder"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_manage"
                android:contentDescription="Builder"
                android:backgroundTint="#555" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Build"
                android:textColor="#555"
                android:textSize="9sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- JARVIS -->
        <LinearLayout
            android:id="@+id/nav_jarvis"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_search"
                android:contentDescription="JARVIS"
                android:backgroundTint="#555" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JARVIS"
                android:textColor="#555"
                android:textSize="9sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Settings -->
        <LinearLayout
            android:id="@+id/nav_settings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_preferences"
                android:contentDescription="Settings"
                android:backgroundTint="#555" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="#555"
                android:textSize="9sp"
                android:fontFamily="monospace" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
