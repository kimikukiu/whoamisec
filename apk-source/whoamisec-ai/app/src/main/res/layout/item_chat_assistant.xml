<?xml version="1.0" encoding="utf-8"?>
<!-- Chat message item — Assistant -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start"
    android:paddingTop="4dp"
    android:paddingBottom="4dp"
    android:paddingStart="8dp"
    android:paddingEnd="32dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_maxWidth="280dp"
        android:orientation="vertical"
        android:background="#161625"
        android:padding="10dp"
        android:layout_marginStart="4dp">

        <!-- Builder badge (shown when it's a build response) -->
        <TextView
            android:id="@+id/chat_builder_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔨 BUILDER"
            android:textColor="#8b5cf6"
            android:textSize="9sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:visibility="gone"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/chat_msg_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#e0e0f0"
            android:textSize="13sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/chat_msg_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#555"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:layout_marginTop="4dp" />
    </LinearLayout>
</LinearLayout>
