<?xml version="1.0" encoding="utf-8"?>
<!-- WHOAMISecAI Chat — AI Chat with Model Selector -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0a0a0f">

    <!-- Chat Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#0d0d14"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬 WHOAMISecAI Chat"
                android:textColor="#ffffff"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <!-- Model label (clickable to open selector) -->
            <TextView
                android:id="@+id/chat_model_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GPT-4o"
                android:textColor="#8b5cf6"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Pipeline selector -->
        <Spinner
            android:id="@+id/pipeline_selector"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="#8b5cf6"
            android:entries="@array/pipeline_modes" />
    </LinearLayout>

    <!-- Model Selector (expandable panel) -->
    <LinearLayout
        android:id="@+id/model_selector_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#0d0d14"
        android:visibility="gone">

        <!-- Model selector header -->
        <LinearLayout
            android:id="@+id/model_selector_header"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#08080e"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🤖 Select AI Model (80+)"
                android:textColor="#ffffff"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/selected_model_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GPT-4o"
                android:textColor="#8b5cf6"
                android:textSize="12sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/model_recycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="4dp"
            android:clipToPadding="false"
            android:scrollbars="vertical" />
    </LinearLayout>

    <!-- Chat messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chat_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"
        android:scrollbars="vertical" />

    <!-- Chat input -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0d0d14"
        android:padding="8dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/chat_input"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="#1a1a2e"
            android:hint="Type a message…"
            android:textColorHint="#444"
            android:textColor="#ffffff"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:imeOptions="flagNoEnterAction|actionSend"
            android:importantForAutofill="no" />

        <Button
            android:id="@+id/chat_send"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:text="▶"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:background="#8b5cf6"
            android:padding="0dp" />
    </LinearLayout>
</LinearLayout>
