<?xml version="1.0" encoding="utf-8"?>
<!-- Native Chat Panel Layout -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0a0a0f">

    <!-- Chat Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#0d0d14"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@mipmap/ic_launcher_round"
            android:contentDescription="WHOAMISecAI" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WHOAMISecAI Chat"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/chat_model_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NVIDIA Nemotron 70B"
                android:textColor="#8b5cf6"
                android:textSize="11sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Pipeline selector -->
        <Spinner
            android:id="@+id/pipeline_selector"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#8b5cf6"
            android:entries="@array/pipeline_modes" />
    </LinearLayout>

    <!-- Model selector row -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#08080e"
        android:scrollbars="none">

        <RadioGroup
            android:id="@+id/model_selector"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:gravity="center_vertical">

            <RadioButton
                android:id="@+id/model_llm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LLM"
                android:textColor="#10b981"
                android:buttonTint="#10b981"
                android:checked="false" />

            <RadioButton
                android:id="@+id/model_mlm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="MLM"
                android:textColor="#3b82f6"
                android:buttonTint="#3b82f6"
                android:checked="false" />

            <RadioButton
                android:id="@+id/model_allm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="ALLM"
                android:textColor="#8b5cf6"
                android:buttonTint="#8b5cf6"
                android:checked="true" />
        </RadioGroup>
    </HorizontalScrollView>

    <!-- Chat messages list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chat_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"
        android:scrollbars="vertical" />

    <!-- Chat input area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0d0d14"
        android:padding="8dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/chat_input"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="#1a1a2e"
            android:hint="@string/chat_hint"
            android:textColorHint="#444"
            android:textColor="#ffffff"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:imeOptions="flagNoEnterAction"
            android:importantForAutofill="no" />

        <ImageButton
            android:id="@+id/chat_send"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="#8b5cf6"
            android:contentDescription="Send"
            android:padding="8dp"
            android:tint="#ffffff" />
    </LinearLayout>
</LinearLayout>
