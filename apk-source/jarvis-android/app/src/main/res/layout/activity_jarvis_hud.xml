<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/jarvis_bg">

    <!-- Floating Particles Background -->
    <com.whoamisecai.jarvis.hud.JarvisParticlesView
        android:id="@+id/particles_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Status Bar -->
    <TextView
        android:id="@+id/jarvis_status"
        style="@style/JarvisTextStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="@string/status_idle"
        android:alpha="0.7"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Engine Mode Indicator -->
    <TextView
        android:id="@+id/jarvis_engine_mode"
        style="@style/JarvisTextGreen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="GOOGLE STT"
        android:textSize="10sp"
        android:alpha="0.4"
        app:layout_constraintTop_toBottomOf="@id/jarvis_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Circular Audio Level Indicator -->
    <com.whoamisecai.jarvis.hud.JarvisHudView
        android:id="@+id/jarvis_hud_view"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/jarvis_engine_mode"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Transcript (User speech) -->
    <TextView
        android:id="@+id/jarvis_transcript"
        style="@style/JarvisTranscript"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:textColor="@color/jarvis_text"
        android:hint="Awaiting voice input..."
        android:textColorHint="@color/jarvis_dim"
        android:maxLines="3"
        android:ellipsize="end"
        app:layout_constraintTop_toBottomOf="@id/jarvis_hud_view"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Response (JARVIS reply) -->
    <TextView
        android:id="@+id/jarvis_response"
        style="@style/JarvisResponse"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:textColor="@color/jarvis_primary"
        android:hint=""
        android:textColorHint="@color/jarvis_dim"
        android:maxLines="6"
        android:ellipsize="end"
        app:layout_constraintTop_toBottomOf="@id/jarvis_transcript"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Audio Level Bar -->
    <View
        android:id="@+id/jarvis_audio_bar"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:layout_marginBottom="48dp"
        android:layout_marginStart="64dp"
        android:layout_marginEnd="64dp"
        android:background="@color/jarvis_ring"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Debug Info (small, dimmed) -->
    <TextView
        android:id="@+id/jarvis_debug"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="v7.0-voice-fixed"
        android:textColor="@color/jarvis_dim"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:alpha="0.3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
